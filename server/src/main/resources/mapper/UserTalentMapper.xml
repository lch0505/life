<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.life.progress.mapper.UserTalentMapper">

    <resultMap id="BaseResultMap" type="com.life.progress.entity.UserTalent">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="appearance" property="appearance"/>
        <result column="intelligence" property="intelligence"/>
        <result column="wealth" property="wealth"/>
        <result column="health" property="health"/>
        <result column="emotional" property="emotional"/>
        <result column="luck" property="luck"/>
        <result column="total_points_used" property="totalPointsUsed"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM user_talent WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM user_talent WHERE user_id = #{userId}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM user_talent ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_talent (
            user_id, appearance, intelligence, wealth, health, emotional, luck, total_points_used
        ) VALUES (
            #{userId}, #{appearance}, #{intelligence}, #{wealth}, #{health}, #{emotional}, #{luck}, #{totalPointsUsed}
        )
    </insert>

    <update id="update">
        UPDATE user_talent SET
            appearance = #{appearance},
            intelligence = #{intelligence},
            wealth = #{wealth},
            health = #{health},
            emotional = #{emotional},
            luck = #{luck},
            total_points_used = #{totalPointsUsed}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM user_talent WHERE id = #{id}
    </delete>

    <delete id="deleteByUserId">
        DELETE FROM user_talent WHERE user_id = #{userId}
    </delete>

</mapper>
