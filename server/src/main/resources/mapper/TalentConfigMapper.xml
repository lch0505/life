<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.life.progress.mapper.TalentConfigMapper">

    <resultMap id="BaseResultMap" type="com.life.progress.entity.TalentConfig">
        <id column="id" property="id"/>
        <result column="config_key" property="configKey"/>
        <result column="config_value" property="configValue"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM talent_config WHERE id = #{id}
    </select>

    <select id="selectByKey" resultMap="BaseResultMap">
        SELECT * FROM talent_config WHERE config_key = #{configKey}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM talent_config ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO talent_config (
            config_key, config_value, description
        ) VALUES (
            #{configKey}, #{configValue}, #{description}
        )
    </insert>

    <update id="update">
        UPDATE talent_config SET
            config_value = #{configValue},
            description = #{description}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM talent_config WHERE id = #{id}
    </delete>

    <delete id="deleteByKey">
        DELETE FROM talent_config WHERE config_key = #{configKey}
    </delete>

</mapper>
