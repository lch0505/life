<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.life.progress.mapper.TalentSimulationLogMapper">

    <resultMap id="BaseResultMap" type="com.life.progress.entity.TalentSimulationLog">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="simulation_type" property="simulationType"/>
        <result column="simulation_result" property="simulationResult"/>
        <result column="talent_snapshot" property="talentSnapshot"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM talent_simulation_log WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM talent_simulation_log WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <select id="selectByUserIdAndType" resultMap="BaseResultMap">
        SELECT * FROM talent_simulation_log 
        WHERE user_id = #{userId} AND simulation_type = #{simulationType} 
        ORDER BY create_time DESC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM talent_simulation_log ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO talent_simulation_log (
            user_id, simulation_type, simulation_result, talent_snapshot
        ) VALUES (
            #{userId}, #{simulationType}, #{simulationResult}, #{talentSnapshot}
        )
    </insert>

    <delete id="deleteById">
        DELETE FROM talent_simulation_log WHERE id = #{id}
    </delete>

    <delete id="deleteByUserId">
        DELETE FROM talent_simulation_log WHERE user_id = #{userId}
    </delete>

</mapper>
